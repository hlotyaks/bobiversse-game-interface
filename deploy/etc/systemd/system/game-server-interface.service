[Unit]
Description=Game Server Interface Web Application
After=docker.service game-server-interface-controller.service
Requires=docker.service game-server-interface-controller.service

[Service]
Type=simple
WorkingDirectory=/opt/game-server-interface
ExecStartPre=/usr/bin/docker compose --project-directory /opt/game-server-interface --file /opt/game-server-interface/compose.yaml config -q
ExecStart=/usr/bin/docker compose --project-directory /opt/game-server-interface --file /opt/game-server-interface/compose.yaml up --no-color --remove-orphans
ExecStop=/usr/bin/docker compose --project-directory /opt/game-server-interface --file /opt/game-server-interface/compose.yaml down
Restart=on-failure
RestartSec=10s
TimeoutStartSec=2min
TimeoutStopSec=30s

[Install]
WantedBy=multi-user.target
